{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/accounts/layout,_N_T_/(app)/accounts/page,_N_T_/accounts"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/accounts/__PAGE__",
    "/!KGFwcCk/accounts",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}